# Public browser API origin (no trailing slash). When unset, clinical/constitution pages use local mock responses.
NEXT_PUBLIC_API_BASE=

# PostgreSQL 连接串（Vercel / Neon / Supabase 控制台复制；含 ssl 参数）
# 本地 Docker：docker compose up -d 后示例如下
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dbcnet?schema=public"
DATABASE_URL=

# 会话签名密钥，至少 16 字符，勿提交真实值
AUTH_SECRET="替换成_随机长字符串_至少16位"

# 种子用户（npx prisma db seed）：demo@example.com / demo1234
