{
  "name": "dbcnet-tcm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true});}catch(e){if(e.code!=='ENOENT')throw e;}\"",
    "dev": "next dev",
    "dev:safe": "node scripts/dev-safe.mjs",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "build:safe": "node scripts/build-safe.mjs",
    "build:clean": "npm run clean && next build",
    "redeploy": "npm run build:clean && next start",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
}
